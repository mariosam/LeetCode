package GO

import (
	"reflect"
	"testing"
)

func TestFindTheMaximumNumberOfElementsInSubset(t *testing.T) {
	tables := []struct {
		want int
		nums []int
	}{
		{3, []int{5, 4, 1, 2, 2}},
		{1, []int{1, 3, 2, 4}},
	}

	for _, table := range tables {
		got := maximumLength(table.nums)

		if !reflect.DeepEqual(got, table.want) {
			t.Errorf("Waiting for this %d but the return was this: %d", table.want, got)
		}
	}
}
